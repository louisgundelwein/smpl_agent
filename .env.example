# OpenAI-compatible LLM Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# For custom endpoints (e.g. DeutschlandGPT):
# OPENAI_BASE_URL=https://apiv2.deutschlandgpt.de/platform-api/api/v2
# OPENAI_MODEL=gemini-2.5-flash

# Brave Search Configuration
BRAVE_SEARCH_API_KEY=

# Daemon/Attach Configuration
AGENT_HOST=127.0.0.1
AGENT_PORT=7600

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Memory Configuration
EMBEDDING_MODEL=text-embedding-3-large
MEMORY_DB_PATH=agent_memory.db

# Soul / System Prompt
SOUL_PATH=SOUL.md

# Shell Tool Configuration
SHELL_COMMAND_TIMEOUT=30
SHELL_MAX_OUTPUT=50000

# Context Management
CONTEXT_MAX_TOKENS=100000
CONTEXT_PRESERVE_RECENT=10

# Agent Loop
MAX_TOOL_ROUNDS=25

# Codex Configuration
CODEX_TIMEOUT=300
CODEX_MAX_OUTPUT=50000

# GitHub Configuration
GITHUB_TOKEN=

# Conversation History
HISTORY_PATH=conversation_history.json

# Whisper Transcription (optional, for voice messages)
# Dependencies (torch, transformers, accelerate) are auto-installed on first use.
# Requires ffmpeg on the system PATH for OGG/Opus decoding.
WHISPER_MODEL=openai/whisper-large-v3-turbo

# Daemon Configuration
DAEMON_PID_PATH=agent.pid
DAEMON_LOG_PATH=agent.log
